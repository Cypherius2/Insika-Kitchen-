rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'stock']) &&
             data.keys().size() <= 10 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             (!('image' in data) || (data.image == null || (data.image is string && data.image.size() <= 1000))) &&
             (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt) &&
             (resource == null ? (!('updatedAt' in data) || data.updatedAt == request.time) : true);
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['name']) &&
             data.keys().size() <= 10 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             (!('email' in data) || (data.email == null || (data.email is string && data.email.size() <= 150))) &&
             (!('phone' in data) || (data.phone == null || (data.phone is string && data.phone.size() <= 50))) &&
             (!('address' in data) || (data.address == null || (data.address is string && data.address.size() <= 2000))) &&
             (resource == null ? (!('createdAt' in data) || data.createdAt == request.time) : data.createdAt == resource.data.createdAt) &&
             (resource == null ? (!('updatedAt' in data) || data.updatedAt == request.time) : true);
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['documentNumber', 'type', 'totalAmount', 'items', 'customer']) &&
             data.keys().size() <= 20 &&
             data.documentNumber is string &&
             data.type in ['invoice', 'receipt', 'quotation'] &&
             data.totalAmount is number &&
             data.items is list &&
             data.customer is map &&
             (resource == null ? data.createdAt == request.time : data.createdAt == resource.data.createdAt);
    }

    function isValidSettings(data) {
      return data.keys().size() <= 5 &&
             (!('businessName' in data) || (data.businessName is string && data.businessName.size() <= 100)) &&
             (!('brandColor' in data) || (data.brandColor is string && data.brandColor.size() <= 30)) &&
             (!('vatRate' in data) || (data.vatRate is number && data.vatRate >= 0)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 1000)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp));
    }

    // Role-based access could be added here. For a small business, we'll allow all signed-in users.
    // In a prod app, we'd check for a 'staff' or 'admin' flag on the user document.

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isSignedIn() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'price', 'stock', 'image', 'updatedAt'])
      );
      allow delete: if isSignedIn();
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomer(incoming()) && isValidId(customerId);
      allow update: if isSignedIn() && isValidCustomer(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'address', 'updatedAt'])
      );
      allow delete: if isSignedIn();
    }

    match /documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDocument(incoming()) && isValidId(docId);
      allow delete: if isSignedIn();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidSettings(incoming()) && isValidId(docId);
    }
  }
}
