rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Validation Helpers
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             (!('category' in data) || (data.category is string && data.category.size() <= 500)) &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('stock' in data) || (data.stock is number)) &&
             (!('image' in data) || (data.image == null || (data.image is string && data.image.size() <= 2000))) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == request.time);
    }

    function isValidCustomer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 500 &&
             (!('email' in data) || (data.email == null || (data.email is string && data.email.size() <= 500))) &&
             (!('phone' in data) || (data.phone == null || (data.phone is string && data.phone.size() <= 100))) &&
             (!('address' in data) || (data.address == null || (data.address is string && data.address.size() <= 5000))) &&
             (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == request.time);
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['documentNumber', 'type', 'totalAmount', 'items', 'customer']) &&
             data.documentNumber is string &&
             data.type in ['invoice', 'receipt', 'quotation'] &&
             data.totalAmount is number &&
             data.items is list &&
             data.customer is map &&
             (!('status' in data) || data.status is string) &&
             (!('subtotal' in data) || data.subtotal is number) &&
             (!('vat' in data) || data.vat is number) &&
             (!('businessName' in data) || (data.businessName == null || data.businessName is string)) &&
             (!('logoUrl' in data) || (data.logoUrl == null || data.logoUrl is string)) &&
             (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidSettings(data) {
      return (!('businessName' in data) || (data.businessName is string && data.businessName.size() <= 500)) &&
             (!('brandColor' in data) || (data.brandColor is string && data.brandColor.size() <= 100)) &&
             (!('vatRate' in data) || (data.vatRate is number && data.vatRate >= 0)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() <= 2000)) &&
             (!('lowStockThreshold' in data) || (data.lowStockThreshold is number && data.lowStockThreshold >= 0)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt == request.time) &&
             (!('autoEmail' in data) || (data.autoEmail is bool));
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming());
      allow update: if isSignedIn() && (
        // Action: Update Stock
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'updatedAt']) ||
         incoming().diff(existing()).affectedKeys().hasOnly(['stock'])) ||
        // Action: Update Product Details
        isValidProduct(incoming())
      );
      allow delete: if isSignedIn();
    }

    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCustomer(incoming());
      allow update: if isSignedIn() && isValidCustomer(incoming());
      allow delete: if isSignedIn();
    }

    match /documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDocument(incoming());
      allow delete: if isSignedIn();
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidSettings(incoming());
    }
  }
}
