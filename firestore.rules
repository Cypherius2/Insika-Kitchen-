rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && 
             ( (request.auth.token.email != null && request.auth.token.email.lower() == 'mrcypher68@gmail.com') || 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin'
             ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return (data.get('uid', userId) == userId) &&
               (data.get('role', 'user') in ['admin', 'user']);
      }
      allow get: if isSignedIn(); // Allow looking up users (e.g. for user management list)
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                        (incoming().diff(existing()).affectedKeys().hasOnly(['businessName', 'displayName', 'photoURL']) ||
                         (request.auth.token.email.lower() == 'mrcypher68@gmail.com' && incoming().diff(existing()).affectedKeys().hasOnly(['businessName', 'displayName', 'photoURL', 'role'])))) ||
                    (isAdmin() && isValidUser(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['role']));
    }

    // Products
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.price is number && data.price >= 0 &&
               data.stock is number &&
               data.category is string &&
               (data.get('description', '') is string) &&
               (data.get('variants', []) is list) &&
               data.createdAt is timestamp &&
               data.updatedAt is timestamp;
      }
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(productId);
      allow create: if isSignedIn() && isValidProduct(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidProduct(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'stock', 'category', 'description', 'variants', 'updatedAt']);
      allow delete: if isAdmin();
    }

    // Customers
    match /customers/{customerId} {
      function isValidCustomer(data) {
        return data.name is string && data.name.size() > 0 &&
               data.email is string && data.email.size() > 0 &&
               data.createdAt is timestamp;
      }
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(customerId);
      allow create: if isSignedIn() && isValidCustomer(incoming()) && 
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidCustomer(incoming());
      allow delete: if isAdmin();
    }

    // Transactions
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return (data.get('docId', '') is string) &&
               (data.get('type', 'INVOICE') in ['INVOICE', 'QUOTATION', 'RECEIPT']) &&
               (data.get('total', 0) is number) &&
               (data.get('status', 'PENDING') is string) &&
               (data.get('customerName', '') is string) &&
               (data.get('customerEmail', '') is string) &&
               (data.get('date', '') is string) &&
               (data.get('items', []) is list) &&
               (data.get('createdAt', request.time) is timestamp) &&
               (data.get('updatedAt', request.time) is timestamp);
      }
      allow list, get: if isAdmin();
      allow create: if isSignedIn() && isValidTransaction(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isAdmin() && isValidTransaction(incoming()) &&
                    incoming().get('createdAt', existing().createdAt) == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'type', 'date']);
    }

    // Notifications
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.title is string && data.title.size() > 0 &&
               data.message is string && data.message.size() > 0 &&
               data.type in ['INFO', 'WARNING', 'CRITICAL', 'SUCCESS'] &&
               data.read is bool &&
               data.createdAt is timestamp;
      }
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(notificationId);
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isAdmin();
    }
  }
}
