{
  "entities": {
    "products": {
      "title": "Product",
      "description": "Inventory units within the system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sku": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "stock": { "type": "number" }
            },
            "required": ["sku", "name", "price", "stock"]
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "category"]
    },
    "users": {
      "title": "User",
      "description": "System users and their permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "businessName": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "customers": {
      "title": "Customer",
      "description": "Entities interacting with the business OS",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "sector": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email"]
    },
    "transactions": {
      "title": "Transaction",
      "description": "Financial ledger entries",
      "type": "object",
      "properties": {
        "docId": { "type": "string" },
        "type": { "type": "string", "enum": ["INVOICE", "QUOTATION", "RECEIPT"] },
        "customerName": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["docId", "type", "customerName", "total", "status"]
    },
    "notifications": {
      "title": "Notification",
      "description": "System alerts and notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["INFO", "WARNING", "CRITICAL", "SUCCESS"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "users": { "schema": "users", "description": "System user profiles" },
    "products": { "schema": "products", "description": "Global inventory list" },
    "customers": { "schema": "customers", "description": "Customer directory" },
    "transactions": { "schema": "transactions", "description": "Financial records" },
    "notifications": { "schema": "notifications", "description": "System alerts and telemetry" }
  }
}
