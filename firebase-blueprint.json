{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Menu items and inventory products",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the product" },
        "category": { "type": "string", "description": "Product category" },
        "price": { "type": "number", "description": "Unit price" },
        "stock": { "type": "integer", "description": "Current inventory level" },
        "image": { "type": "string", "format": "uri", "description": "Optional image URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "category", "price", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client directory and contact info",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "email": { "type": "string", "format": "email", "description": "Contact email" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "address": { "type": "string", "description": "Physical address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp" }
      },
      "required": ["name"]
    },
    "Document": {
      "title": "Document",
      "description": "Invoices, Receipts, and Quotations",
      "type": "object",
      "properties": {
        "documentNumber": { "type": "string" },
        "type": { "type": "string", "enum": ["invoice", "receipt", "quotation"] },
        "customer": { "type": "object" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "vat": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["documentNumber", "type", "totalAmount"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "brandColor": { "type": "string" },
        "vatRate": { "type": "number" },
        "logoUrl": { "type": "string", "format": "uri" }
      }
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Inventory of products"
    },
    "customers": {
      "schema": "Customer",
      "description": "Customer profiles"
    },
    "documents": {
      "schema": "Document",
      "description": "Sales documents and activities"
    },
    "settings": {
      "schema": "Settings",
      "description": "App-wide settings"
    }
  }
}
