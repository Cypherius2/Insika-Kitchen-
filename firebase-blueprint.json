{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Bakery products and items for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Client information for tracking sales and documents",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "Document": {
      "title": "Document",
      "description": "Invoices, quotations, and receipts generated by the system",
      "type": "object",
      "properties": {
        "documentNumber": { "type": "string" },
        "type": { "enum": ["quotation", "invoice", "receipt"] },
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "vat": { "type": "number" },
        "totalAmount": { "type": "number" },
        "status": { "enum": ["draft", "approved", "paid", "cancelled"] },
        "linkedTo": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["documentNumber", "type", "items", "totalAmount"]
    },
    "Counter": {
      "title": "Counter",
      "description": "Auto-increment counters for document numbering",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "currentNumber": { "type": "number" }
      },
      "required": ["type", "currentNumber"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of bakery products"
    },
    "customers": {
      "schema": "Customer",
      "description": "Collection of business customers"
    },
    "documents": {
      "schema": "Document",
      "description": "Collection of all financial documents"
    },
    "counters": {
      "schema": "Counter",
      "description": "System counters for auto-incrementing IDs"
    }
  }
}
